---
import PublicationCard from './PublicationCard.astro';
import publications from '../data/publications.json';

const years = [...new Set(publications.map(p => p.year))].sort((a, b) => b - a);
const venues = [...new Set(publications.map(p => p.venue))].sort();
---

<section id="publications" class="py-10 animate-on-scroll">
  <div class="max-w-3xl mx-auto px-6">
    <div class="flex items-center gap-4 mb-6">
      <h2 class="section-heading !mb-0">Selected Research</h2>
      <div class="flex flex-wrap gap-2" id="filter-bar">
        <button class="filter-pill active" data-filter="all">All</button>
        <button class="filter-pill" data-filter="cat-post-training">Post-training</button>
        <button class="filter-pill" data-filter="cat-benchmarking">Benchmarking</button>
      </div>
    </div>

    <div class="divide-y divide-[#DDD6CC]/40 dark:divide-[#2E2C28]/60" id="publications-list">
      {publications.map((pub, index) => (
        <PublicationCard pub={pub} index={index} />
      ))}
    </div>

    <p class="mt-6 text-center">
      <a href="https://scholar.google.com/citations?user=g6grFy0AAAAJ&hl" target="_blank" rel="noopener noreferrer"
        class="font-mono text-[11px] text-[#9B948E] dark:text-[#6B6460] hover:text-[#8BA89A] dark:hover:text-[#A3BDAE] transition-colors">
        Full publication list &rarr;
      </a>
    </p>
  </div>
</section>

<script is:inline>
(function () {
  var filterBar = document.getElementById('filter-bar');
  var cards = document.querySelectorAll('#publications-list article');

  function filterCards(filter) {
    // Update active pill
    if (filterBar) {
      filterBar.querySelectorAll('.filter-pill').forEach(function(b) { b.classList.remove('active'); });
      var match = filterBar.querySelector('[data-filter="' + filter + '"]');
      if (match) match.classList.add('active');
      else filterBar.querySelector('[data-filter="all"]')?.classList.remove('active');
    }

    cards.forEach(function(card) {
      if (filter === 'all') { card.classList.remove('hidden'); return; }
      // Category filter (from hero links)
      if (filter.indexOf('cat-') === 0) {
        var cat = filter.substring(4);
        var cats = (card.dataset.categories || '').split(',');
        card.classList.toggle('hidden', cats.indexOf(cat) === -1);
        return;
      }
      // Year/venue filter (from pill buttons)
      var parts = filter.split('-'), type = parts[0], value = parts.slice(1).join('-');
      card.classList.toggle('hidden', type === 'year' ? card.dataset.year !== value : card.dataset.venue !== value);
    });
  }

  // Filter bar clicks
  filterBar?.addEventListener('click', function(e) {
    var btn = e.target.closest('.filter-pill');
    if (!btn) return;
    filterCards(btn.dataset.filter);
  });

  // Hero keyword clicks
  document.querySelectorAll('[data-filter-cat]').forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      var cat = link.dataset.filterCat;
      filterCards('cat-' + cat);
      document.getElementById('publications')?.scrollIntoView({ behavior: 'smooth' });
    });
  });

  // Mouse glow
  document.querySelectorAll('.card-glow').forEach(function(c) {
    c.addEventListener('mousemove', function(e) {
      var r = c.getBoundingClientRect();
      c.style.setProperty('--mouse-x', (e.clientX - r.left) + 'px');
      c.style.setProperty('--mouse-y', (e.clientY - r.top) + 'px');
    });
  });
})();
</script>
