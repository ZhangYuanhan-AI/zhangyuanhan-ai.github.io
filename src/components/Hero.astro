<section class="relative overflow-hidden pt-16 pb-10 md:pt-24 md:pb-14">
  <div class="max-w-3xl mx-auto px-6">
    <div class="flex flex-col-reverse md:flex-row items-center gap-8 md:gap-14">
      <div class="flex-1 text-center md:text-left">
        <h1>
          <span class="block text-4xl sm:text-5xl md:text-6xl font-black tracking-tighter text-[#3D3835] dark:text-[#C4BCB4] leading-[0.9]">YUANHAN</span>
          <span class="glitch-text block text-4xl sm:text-5xl md:text-6xl font-black tracking-tighter leading-[0.9] gradient-text" data-text="ZHANG">ZHANG</span>
        </h1>

        <a href="https://translate.google.com/?hl=zh-CN&sl=auto&tl=zh-CN&text=%E5%85%83%E7%80%9A&op=translate" target="_blank" rel="noopener noreferrer"
          aria-label="Listen to Chinese pronunciation of Yuanhan"
          class="inline-flex items-center gap-1.5 mt-2 hover:opacity-80 transition-opacity">
          <span class="text-base gradient-text font-bold">张</span><span class="text-base text-[#3D3835] dark:text-[#C4BCB4]">元瀚</span>
          <span class="font-mono text-[10px] text-[#9B948E] dark:text-[#6B6460]">Yuanhan (John) Zhang</span>
        </a>

        <div class="mt-3 font-mono text-xs text-[#9B948E] dark:text-[#6B6460] h-5">
          <span id="typed-strike" class="hidden line-through decoration-1 decoration-[#C4A6A0]/60"></span>
          <span id="typed-text"></span><span class="animate-blink text-[#8BA89A] dark:text-[#A3BDAE]" aria-hidden="true">_</span>
        </div>

        <p class="mt-4 text-sm text-[#6B6460] dark:text-[#9B948E] sm:whitespace-nowrap">
          Final-year PhD at <a href="https://www.mmlab-ntu.com/" target="_blank" rel="noopener noreferrer" class="text-[#3D3835] dark:text-[#C4BCB4] hover:text-[#8BA89A] dark:hover:text-[#A3BDAE] transition-colors">MMLab@NTU</a>, advised by Prof. <a href="https://liuziwei7.github.io/" target="_blank" rel="noopener noreferrer" class="text-[#3D3835] dark:text-[#C4BCB4] hover:text-[#8BA89A] dark:hover:text-[#A3BDAE] transition-colors">Ziwei Liu</a>.
        </p>
        <p class="mt-2 text-sm text-[#6B6460] dark:text-[#9B948E] max-w-sm leading-relaxed">
          I build and evaluate large language and multimodal models &mdash; from
          <span class="text-[#3D3835] dark:text-[#C4BCB4]">post-training</span> to
          <span class="text-[#3D3835] dark:text-[#C4BCB4]">benchmarking</span>.
        </p>

        <p class="mt-3 text-xs text-[#6B6460] dark:text-[#9B948E] flex items-center gap-2">
          <span class="font-mono text-[10px] font-semibold text-[#8BA89A] dark:text-[#A3BDAE] border border-[#8BA89A]/30 dark:border-[#A3BDAE]/30 rounded px-1.5 py-0.5">New</span>
          <span>
            <a href="https://zhangyuanhan-ai.github.io/video-tt/" target="_blank" rel="noopener noreferrer" class="text-[#8BA89A] dark:text-[#A3BDAE] hover:underline underline-offset-2">Video-TT</a> ICCV'25 &middot;
            <a href="https://llava-vl.github.io/blog/2024-09-30-llava-video/" target="_blank" rel="noopener noreferrer" class="text-[#8BA89A] dark:text-[#A3BDAE] hover:underline underline-offset-2">LLaVA-Video</a> &amp;
            <a href="https://llava-vl.github.io/blog/2024-08-05-llava-onevision/" target="_blank" rel="noopener noreferrer" class="text-[#8BA89A] dark:text-[#A3BDAE] hover:underline underline-offset-2">OneVision</a> TMLR'25
          </span>
        </p>

        <div class="mt-5 flex flex-wrap justify-center md:justify-start gap-3">
          <a href="mailto:yuanhan002@e.ntu.edu.sg" class="font-mono text-[11px] text-[#9B948E] dark:text-[#6B6460] hover:text-[#8BA89A] dark:hover:text-[#A3BDAE] transition-colors">Email</a>
          <a href="https://scholar.google.com/citations?user=g6grFy0AAAAJ&hl" target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] text-[#9B948E] dark:text-[#6B6460] hover:text-[#8BA89A] dark:hover:text-[#A3BDAE] transition-colors">Scholar</a>
          <a href="https://twitter.com/zhang_yuanhan" target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] text-[#9B948E] dark:text-[#6B6460] hover:text-[#8BA89A] dark:hover:text-[#A3BDAE] transition-colors">Twitter</a>
          <a href="https://github.com/ZhangYuanhan-AI" target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] text-[#9B948E] dark:text-[#6B6460] hover:text-[#8BA89A] dark:hover:text-[#A3BDAE] transition-colors">GitHub</a>
          <a href="https://www.linkedin.com/in/yuanhan-zhang-b09a95b5/" target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] text-[#9B948E] dark:text-[#6B6460] hover:text-[#8BA89A] dark:hover:text-[#A3BDAE] transition-colors">LinkedIn</a>
        </div>
      </div>

      <div class="flex-shrink-0 relative group">
        <div class="absolute -inset-6 rounded-full bg-[#8BA89A]/[0.04] blur-2xl group-hover:bg-[#8BA89A]/[0.07] transition-all duration-700"></div>
        <a href="/images/zyh_5.png" target="_blank" rel="noopener noreferrer" class="relative block">
          <img src="/images/zyh_5_circle.jpg" alt="Yuanhan Zhang" loading="eager"
            class="relative w-44 h-44 md:w-56 md:h-56 rounded-full object-cover ring-1 ring-[#DDD6CC] dark:ring-[#2E2C28] group-hover:ring-[#8BA89A]/40 dark:group-hover:ring-[#A3BDAE]/30 transition-all duration-700" />
        </a>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(function() {
  var el = document.getElementById('typed-text');
  var strike = document.getElementById('typed-strike');
  if (!el || !strike) return;

  var q1 = 'What can AI do for you?';
  var q2 = 'What can you do for AI?';
  var ci = 0;

  function typeQ1() {
    el.textContent = q1.substring(0, ci + 1);
    ci++;
    if (ci === q1.length) { setTimeout(doStrike, 1200); return; }
    setTimeout(typeQ1, 50 + Math.random() * 30);
  }

  function doStrike() {
    strike.textContent = q1;
    strike.classList.remove('hidden');
    el.textContent = ' ';
    ci = 0;
    setTimeout(typeQ2, 400);
  }

  function typeQ2() {
    el.textContent = ' ' + q2.substring(0, ci + 1);
    ci++;
    if (ci === q2.length) { setTimeout(reset, 3000); return; }
    setTimeout(typeQ2, 50 + Math.random() * 30);
  }

  function reset() {
    strike.textContent = '';
    strike.classList.add('hidden');
    el.textContent = '';
    ci = 0;
    setTimeout(typeQ1, 500);
  }

  setTimeout(typeQ1, 800);
})();
</script>
