            <span class="text-[#6B6460] dark:text-[#A39D97]">
              <a href="https://videommmu.github.io/" target="_blank" rel="noopener noreferrer" class="text-[#8BA89A] dark:text-[#A3BDAE] hover:underline underline-offset-2">Video-MMMU</a>
              <span class="text-[#3D3835] dark:text-[#C4BCB4]">ACL'26</span>
            </span>
          </div>
          <!-- Secondary news (older, muted) -->
          <div class="flex flex-wrap justify-center md:justify-start items-center gap-x-1.5 mt-1 ml-0 md:ml-[46px] text-[#9B948E] dark:text-[#7A746E]">
