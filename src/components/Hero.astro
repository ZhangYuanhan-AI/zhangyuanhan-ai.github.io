<section class="relative overflow-hidden pt-16 pb-10 md:pt-24 md:pb-14">
  <div class="max-w-3xl mx-auto px-6">
    <div class="flex flex-col-reverse md:flex-row items-center gap-8 md:gap-14">
      <div class="flex-1 text-center md:text-left">
        <h1>
          <span class="block text-4xl sm:text-5xl md:text-6xl font-black tracking-tighter text-[#3D3835] dark:text-[#C4BCB4] leading-[0.9]">YUANHAN <span class="text-lg sm:text-xl md:text-2xl font-semibold text-[#9B948E] dark:text-[#6B6460] tracking-normal">(John)</span></span>
          <span class="block text-4xl sm:text-5xl md:text-6xl font-black tracking-tighter leading-[0.9] gradient-text">ZHANG</span>
        </h1>

        <a href="https://translate.google.com/?hl=zh-CN&sl=auto&tl=zh-CN&text=%E5%85%83%E7%80%9A&op=translate" target="_blank" rel="noopener noreferrer"
          aria-label="Listen to Chinese pronunciation"
          class="inline-flex items-center gap-1.5 mt-2 hover:opacity-80 transition-opacity text-[#9B948E] dark:text-[#6B6460]">
          <span class="text-base"><span class="gradient-text font-bold">张</span> <span class="text-[#3D3835] dark:text-[#C4BCB4]">元瀚</span></span>
        </a>

        <p class="mt-5 text-[15px] text-[#6B6460] dark:text-[#A39D97] sm:whitespace-nowrap leading-normal">
          Final-year PhD at <a href="https://www.mmlab-ntu.com/" target="_blank" rel="noopener noreferrer" class="text-[#3D3835] dark:text-[#C4BCB4] hover:text-[#8BA89A] dark:hover:text-[#A3BDAE] transition-colors">MMLab@NTU</a>, advised by Prof. <a href="https://liuziwei7.github.io/" target="_blank" rel="noopener noreferrer" class="text-[#3D3835] dark:text-[#C4BCB4] hover:text-[#8BA89A] dark:hover:text-[#A3BDAE] transition-colors">Ziwei Liu</a>.
        </p>
        <p class="mt-2 text-[15px] text-[#6B6460] dark:text-[#A39D97] max-w-sm leading-relaxed">
          I build and evaluate multimodal large language models, with a focus on
          <span class="text-[#3D3835] dark:text-[#C4BCB4]">post-training</span> and
          <span class="text-[#3D3835] dark:text-[#C4BCB4]">benchmarking</span>.
        </p>

        <!-- News — two-tier layout -->
        <div class="mt-5 text-[11px]">
